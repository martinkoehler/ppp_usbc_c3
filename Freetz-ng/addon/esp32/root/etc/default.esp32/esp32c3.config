/dev/ttyACM0 115200
local
# Reconnect forever
persist
maxfail 0
holdoff 5

# Detect dead peer
lcp-echo-interval 5
lcp-echo-failure 3

lock
noauth
nocrtscts
novj
nobsdcomp
nopcomp
noaccomp
nodetach
asyncmap 0xa0000
escape 0x11,0x13,0x7d,0x7e
ipcp-accept-local
ipcp-accept-remote
192.168.178.83:192.168.178.250
ms-dns 192.168.178.1
# optional, if your Wemos needs a kick:
# connect '/bin/sh -c "echo -e CLIENT; sleep 1"'
# Optional: Enable debug for troubleshooting
# debug
