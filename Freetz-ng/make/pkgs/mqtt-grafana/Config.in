config FREETZ_PACKAGE_MQTT_GRAFANA
	bool "mqtt-grafana (SQLite JSON endpoint)"
	default n
	select FREETZ_LIB_libsqlite3
	help
	  Read-only CGI endpoint for Grafana. It exposes MQTT messages stored
	  by mqtt2sqlite as JSON through the Freetz web server on port 81.

if FREETZ_PACKAGE_MQTT_GRAFANA

config FREETZ_PACKAGE_MQTT_GRAFANA_TOPIC
	string "Dashboard power topic" if !FREETZ_PACKAGE_ESP32C3
	default FREETZ_PACKAGE_ESP32C3_GRAFANA_TOPIC if FREETZ_PACKAGE_ESP32C3
	default "OBK-681/power/get"
	help
	  Exact MQTT topic displayed by the power dashboard.

config FREETZ_PACKAGE_MQTT_GRAFANA_DB_PATH
	string "SQLite database path" if !FREETZ_PACKAGE_ESP32C3
	default FREETZ_PACKAGE_ESP32C3_MQTT_DB_PATH if FREETZ_PACKAGE_ESP32C3
	default "/var/media/ftp/FLASH-1/mqtt_messages.db"
	help
	  Absolute path to the SQLite database created by mqtt_to_sqlite.

config FREETZ_PACKAGE_MQTT_GRAFANA_MAX_ROWS
	int "Maximum rows per request" if !FREETZ_PACKAGE_ESP32C3
	range 1 100000
	default FREETZ_PACKAGE_ESP32C3_GRAFANA_MAX_ROWS if FREETZ_PACKAGE_ESP32C3
	default 20000
	help
	  Hard upper bound for rows returned by one HTTP request.

config FREETZ_PACKAGE_MQTT_GRAFANA_ALLOWED_IP
	string "Allowed client IP (empty permits all authenticated clients)" if !FREETZ_PACKAGE_ESP32C3
	default FREETZ_PACKAGE_ESP32C3_GRAFANA_ALLOWED_IP if FREETZ_PACKAGE_ESP32C3
	default ""
	help
	  Exact REMOTE_ADDR allowed to use the endpoint, normally the Grafana
	  host IPv4 or IPv6 address. Leave empty to rely on port-81 authentication.

endif
